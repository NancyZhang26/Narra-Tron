# Set to false after installing ML dependencies and testing on target hardware
NARRATRON_USE_MOCK_SERVICES=true

# faster-whisper model size: tiny, base, small, medium, large-v3
NARRATRON_STT_MODEL_SIZE=tiny

# Piper CLI settings (used only when NARRATRON_USE_MOCK_SERVICES=false)
NARRATRON_PIPER_BIN=piper
NARRATRON_PIPER_MODEL_PATH=
NARRATRON_PIPER_SPEAKER_ID=

# Optional macOS say voice for mock-mode spoken output.
# Example: Samantha, Alex, Daniel
NARRATRON_SYSTEM_TTS_VOICE=

NARRATRON_HOST=127.0.0.1
NARRATRON_PORT=8000

# Pico W connection (pi/camera.py uses these to signal the page-turn motor)
# Set PICO_HOST to the IP shown on the Pico's serial output after it connects to WiFi
PICO_HOST=
PICO_PORT=9999

# Camera server (pi/main.py uses CAMERA_HOST to notify camera after page turn)
# Set CAMERA_HOST in pi/main.py directly — MicroPython has no env vars
CAMERA_PORT=9998

# Narra-Tron API base URL as seen from camera.py
NARRATRON_API=http://127.0.0.1:8000

# Number of pages captured per book spread before signalling a page turn
PAGES_PER_SPREAD=2
